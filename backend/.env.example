# MongoDB connection string (required)
# Get this from https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret (required) — use a long, random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# Port the API server listens on (optional, defaults to 5000)
PORT=5000

# Allowed frontend origin for CORS (optional, defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173
